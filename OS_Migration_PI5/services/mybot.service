[Unit]
Description=My ESP32 Bot Service
After=network.target
# Restart if network comes back after being down
Wants=network-online.target

[Service]
Type=simple
User=pi5
WorkingDirectory=/home/pi5/pi5_drive/Git_projects/RASPI5-MAIN

# Activate venv and run the script
ExecStart=/bin/bash -c 'source /home/pi5/myenv/bin/activate && exec python /home/pi5/pi5_drive/Git_projects/RASPI5-MAIN/main.py'

# Environment variables
Environment="PYTHONUNBUFFERED=1"
Environment="PATH=/home/pi5/myenv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="DISPLAY=:0"
Environment="XAUTHORITY=/home/pi5/.Xauthority"
Environment="MQTT_HOST=192.168.1.100"

# Logging: Python logging writes to stdout; telepot network timeout noise goes to stderr.
# Capture structured Python logs to the output file; suppress the raw telepot stderr flood.
StandardOutput=append:/home/pi5/pi5_drive/Git_projects/RASPI5-MAIN/logs/Output_mybot_service.log
StandardError=append:/home/pi5/pi5_drive/Git_projects/RASPI5-MAIN/logs/Error_mybot_service.log

# Restart policy — restart on any exit (crash, OOM, signal, etc.)
Restart=always
RestartSec=10

# If it crashes 5 times within 5 minutes → reboot the Pi
StartLimitBurst=5
StartLimitIntervalSec=300
OnFailure=systemd-reboot.service

[Install]
WantedBy=multi-user.target
